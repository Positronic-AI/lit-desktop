{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://**" }, { "url": "http://**" }]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/lit-server", "sidecar": true },
        { "name": "binaries/jovai-server", "sidecar": true }
      ]
    },
    "shell:allow-kill"
  ]
}
